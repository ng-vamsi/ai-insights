{
  "manifest_version": 3,
  "name": "Sales Audio Insider",
  "version": "1.0",
  "description": "Captures tab and mic audio for sales insights.",
  "permissions": [
    "tabCapture",
    "offscreen",
    "tabs",
    "activeTab",
    "storage",
    "downloads",
    "sidePanel"
  ],
  "action": {
    "default_title": "Open Sales AI Listener"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "host_permissions": [
    "<all_urls>"
  ]
}